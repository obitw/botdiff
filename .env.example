# ── Tokens ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
RIOT_API_KEY=your_riot_api_key

# ── Riot API Routing ────────────────────────────────────────
# Région pour les requêtes Account-V1 & Match-V5 (europe, americas, asia)
RIOT_REGION=europe
# Plateforme pour les liens OP.GG (euw1, na1, kr, etc.)
RIOT_PLATFORM=euw1
